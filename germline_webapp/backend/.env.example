# GermlineRx Backend — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are optional; the app works without any of them.

# --- ClinVar / NCBI ---
# Increases ClinVar rate limit from 3 req/s → 10 req/s.
# Get a free key at: https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your_ncbi_api_key_here

# --- Biomni Datalake ---
# Override the default datalake path if you're not on the same machine.
# Default: ~/Desktop/PROJECTS/Agentic Workflow/Biomni/data/biomni_data/data_lake/
# BIOMNI_DATA_PATH=/path/to/data_lake

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Default: http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,https://your-deployed-frontend.com

# --- Logging ---
# LOG_LEVEL=INFO
